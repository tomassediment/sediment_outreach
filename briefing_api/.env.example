# Copiar a .env y completar valores reales
# NUNCA subir .env a GitHub

ENVIRONMENT=development
API_PORT=8002

# PostgreSQL — misma BD que el resto de Sediment
DATABASE_URL=postgresql://usuario:password@187.77.234.205:5432/nombre_db

# Seguridad — clave que n8n debe pasar en header X-API-Key
API_KEY=cambiar-por-clave-segura

# DEV SAFETY — en development, todos los emails de outreach se redirigen a esta dirección
# Así nunca se envía a un prospecto real durante pruebas
# En producción: dejar vacío (los emails van al destinatario real)
DEV_EMAIL_OVERRIDE=tu-correo-de-prueba@sedimentdata.com

# Twenty CRM — obtener token en Twenty → Settings → API → Generate token
TWENTY_API_URL=http://187.77.234.205:8347
TWENTY_API_TOKEN=
